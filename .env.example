# --- Supabase ---
# Project URL and anon key from Supabase project API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key, server-side only. Used for admin actions and server uploads.
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket name (created via the SQL migration). Default: submissions
SUPABASE_STORAGE_BUCKET=submissions

# --- Resend (email) ---
RESEND_API_KEY=re_your_resend_api_key
# Verified sending domain on Resend, e.g. brand@mycreativestrategist.com
RESEND_FROM_EMAIL=brand@mycreativestrategist.com

# --- Notifications ---
# Where new-submission notifications are sent
ADMIN_NOTIFICATION_EMAIL=andres@mycreativestrategist.com

# --- App ---
# Used for absolute links in emails. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Single admin allowed to access the dashboard
ADMIN_ALLOWED_EMAIL=andres@mycreativestrategist.com

# Calendly link shown on the thank-you screen
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/andres-hdw/30min
